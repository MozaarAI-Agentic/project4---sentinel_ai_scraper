# Copy to .env before running docker compose up.
# Never commit a real .env file - it's gitignored on purpose.

POSTGRES_USER=sentinel
POSTGRES_PASSWORD=change-me-before-any-real-use
POSTGRES_DB=sentinel

# success_rate for the mocked recovery engine (0.0-1.0) - used only when
# ANTHROPIC_API_KEY below is absent.
MOCK_RECOVERY_SUCCESS_RATE=0.7
RECOVERY_MAX_ATTEMPTS=3

# Leave empty to use the mocked recovery engine (default, no cost, fully
# reproducible). Set a real key to activate ClaudeVisionRecoveryEngine -
# see ADR-0016 for why this isn't literally the "Computer Use" tool.
ANTHROPIC_API_KEY=
